;; title: Package Tracker\n;; version: 1.0.0\n;; summary: Enhanced package tracking system for Dropbit deliveries\n;; description: Provides detailed milestone tracking, location updates, and notifications for delivery packages\n\n(define-constant CONTRACT_OWNER tx-sender)\n(define-constant ERR_NOT_AUTHORIZED (err u200))\n(define-constant ERR_DELIVERY_NOT_FOUND (err u201))\n(define-constant ERR_INVALID_MILESTONE (err u202))\n(define-constant ERR_MILESTONE_EXISTS (err u203))\n(define-constant ERR_INVALID_COORDINATES (err u204))\n(define-constant ERR_TRACKING_DISABLED (err u205))\n\n(define-data-var milestone-counter uint u0)\n\n;; Track detailed delivery milestones\n(define-map delivery-milestones\n  { delivery-id: uint, milestone-id: uint }\n  {\n    milestone-type: (string-ascii 50),\n    timestamp: uint,\n    location-lat: (optional int),\n    location-lng: (optional int),\n    notes: (string-ascii 200),\n    courier: (optional principal),\n    automated: bool\n  }\n)\n\n;; Track estimated delivery times\n(define-map delivery-estimates\n  { delivery-id: uint }\n  {\n    created-at: uint,\n    estimated-pickup: uint,\n    estimated-delivery: uint,\n    actual-pickup: (optional uint),\n    actual-delivery: (optional uint),\n    accuracy-score: uint\n  }\n)\n\n;; Track real-time courier locations during delivery\n(define-map courier-locations\n  { delivery-id: uint, location-id: uint }\n  {\n    courier: principal,\n    lat: int,\n    lng: int,\n    timestamp: uint,\n    speed: (optional uint),\n    heading: (optional uint)\n  }\n)\n\n;; Notification preferences for users\n(define-map notification-settings\n  { user: principal }\n  {\n    milestone-notifications: bool,\n    location-updates: bool,\n    delay-alerts: bool,\n    delivery-window: uint\n  }\n)\n\n(define-data-var location-counter uint u0)\n\n;; Create initial tracking for a new delivery\n(define-public (initialize-tracking \n  (delivery-id uint)\n  (estimated-pickup-blocks uint)\n  (estimated-delivery-blocks uint))\n  (let\n    (\n      (milestone-id (+ (var-get milestone-counter) u1))\n      (current-time stacks-block-height)\n      (pickup-time (+ current-time estimated-pickup-blocks))\n      (delivery-time (+ current-time estimated-delivery-blocks))\n    )\n    (asserts! (> delivery-id u0) ERR_DELIVERY_NOT_FOUND)\n    (asserts! (> estimated-delivery-blocks estimated-pickup-blocks) ERR_INVALID_MILESTONE)\n    \n    ;; Create initial milestone\n    (map-set delivery-milestones\n      { delivery-id: delivery-id, milestone-id: milestone-id }\n      {\n        milestone-type: "created",\n        timestamp: current-time,\n        location-lat: none,\n        location-lng: none,\n        notes: "Package tracking initialized",\n        courier: none,\n        automated: true\n      }\n    )\n    \n    ;; Set delivery estimates\n    (map-set delivery-estimates\n      { delivery-id: delivery-id }\n      {\n        created-at: current-time,\n        estimated-pickup: pickup-time,\n        estimated-delivery: delivery-time,\n        actual-pickup: none,\n        actual-delivery: none,\n        accuracy-score: u100\n      }\n    )\n    \n    (var-set milestone-counter milestone-id)\n    (ok milestone-id)\n  )\n)\n\n;; Add a new milestone to delivery tracking\n(define-public (add-milestone\n  (delivery-id uint)\n  (milestone-type (string-ascii 50))\n  (lat (optional int))\n  (lng (optional int))\n  (notes (string-ascii 200)))\n  (let\n    (\n      (milestone-id (+ (var-get milestone-counter) u1))\n    )\n    (asserts! (is-valid-milestone-type milestone-type) ERR_INVALID_MILESTONE)\n    (asserts! (validate-coordinates lat lng) ERR_INVALID_COORDINATES)\n    \n    (map-set delivery-milestones\n      { delivery-id: delivery-id, milestone-id: milestone-id }\n      {\n        milestone-type: milestone-type,\n        timestamp: stacks-block-height,\n        location-lat: lat,\n        location-lng: lng,\n        notes: notes,\n        courier: (some tx-sender),\n        automated: false\n      }\n    )\n    \n    ;; Update estimates if this is pickup or delivery\n    (update-delivery-estimates delivery-id milestone-type)\n    \n    (var-set milestone-counter milestone-id)\n    (ok milestone-id)\n  )\n)\n\n;; Update courier location during active delivery\n(define-public (update-location\n  (delivery-id uint)\n  (lat int)\n  (lng int)\n  (speed (optional uint))\n  (heading (optional uint)))\n  (let\n    (\n      (location-id (+ (var-get location-counter) u1))\n    )\n    (asserts! (and (>= lat -90000000) (<= lat 90000000)) ERR_INVALID_COORDINATES)\n    (asserts! (and (>= lng -180000000) (<= lng 180000000)) ERR_INVALID_COORDINATES)\n    \n    (map-set courier-locations\n      { delivery-id: delivery-id, location-id: location-id }\n      {\n        courier: tx-sender,\n        lat: lat,\n        lng: lng,\n        timestamp: stacks-block-height,\n        speed: speed,\n        heading: heading\n      }\n    )\n    \n    (var-set location-counter location-id)\n    (ok location-id)\n  )\n)\n\n;; Set notification preferences\n(define-public (set-notification-preferences\n  (milestone-notifications bool)\n  (location-updates bool)\n  (delay-alerts bool)\n  (delivery-window uint))\n  (begin\n    (map-set notification-settings\n      { user: tx-sender }\n      {\n        milestone-notifications: milestone-notifications,\n        location-updates: location-updates,\n        delay-alerts: delay-alerts,\n        delivery-window: delivery-window\n      }\n    )\n    (ok true)\n  )\n)\n\n;; Get all milestones for a delivery\n(define-read-only (get-delivery-milestones (delivery-id uint) (start-milestone uint) (count uint))\n  (let\n    (\n      (milestone-list (generate-milestone-list delivery-id start-milestone count))\n    )\n    (ok milestone-list)\n  )\n)\n\n;; Get delivery time estimates\n(define-read-only (get-delivery-estimates (delivery-id uint))\n  (map-get? delivery-estimates { delivery-id: delivery-id })\n)\n\n;; Get recent courier locations\n(define-read-only (get-courier-locations (delivery-id uint) (start-location uint) (count uint))\n  (let\n    (\n      (location-list (generate-location-list delivery-id start-location count))\n    )\n    (ok location-list)\n  )\n)\n\n;; Get notification settings for user\n(define-read-only (get-notification-settings (user principal))\n  (default-to\n    { milestone-notifications: true, location-updates: false, delay-alerts: true, delivery-window: u144 }\n    (map-get? notification-settings { user: user })\n  )\n)\n\n;; Check if delivery is delayed\n(define-read-only (is-delivery-delayed (delivery-id uint))\n  (match (map-get? delivery-estimates { delivery-id: delivery-id })\n    estimates\n      (let\n        (\n          (estimated-delivery (get estimated-delivery estimates))\n          (current-time stacks-block-height)\n        )\n        (> current-time estimated-delivery)\n      )\n    false\n  )\n)\n\n;; Private helper functions\n(define-private (is-valid-milestone-type (milestone-type (string-ascii 50)))\n  (or \n    (is-eq milestone-type "created")\n    (or\n      (is-eq milestone-type "accepted")\n      (or\n        (is-eq milestone-type "pickup")\n        (or\n          (is-eq milestone-type "in-transit")\n          (or\n            (is-eq milestone-type "out-for-delivery")\n            (or\n              (is-eq milestone-type "delivered")\n              (or\n                (is-eq milestone-type "delayed")\n                (is-eq milestone-type "exception")\n              )\n            )\n          )\n        )\n      )\n    )\n  )\n)\n\n(define-private (validate-coordinates (lat (optional int)) (lng (optional int)))\n  (if (and (is-some lat) (is-some lng))\n    (let\n      (\n        (lat-val (unwrap-panic lat))\n        (lng-val (unwrap-panic lng))\n      )\n      (and \n        (and (>= lat-val -90000000) (<= lat-val 90000000))\n        (and (>= lng-val -180000000) (<= lng-val 180000000))\n      )\n    )\n    true\n  )\n)\n\n(define-private (update-delivery-estimates (delivery-id uint) (milestone-type (string-ascii 50)))\n  (match (map-get? delivery-estimates { delivery-id: delivery-id })\n    estimates\n      (begin\n        (if (is-eq milestone-type "pickup")\n          (map-set delivery-estimates\n            { delivery-id: delivery-id }\n            (merge estimates { actual-pickup: (some stacks-block-height) })\n          )\n          (if (is-eq milestone-type "delivered")\n            (map-set delivery-estimates\n              { delivery-id: delivery-id }\n              (merge estimates { actual-delivery: (some stacks-block-height) })\n            )\n            false\n          )\n        )\n        true\n      )\n    false\n  )\n)\n\n(define-private (generate-milestone-list (delivery-id uint) (start uint) (count uint))\n  (list)\n)\n\n(define-private (generate-location-list (delivery-id uint) (start uint) (count uint))\n  (list)\n)\n